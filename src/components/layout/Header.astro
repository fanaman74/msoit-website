---
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'AI Review', href: '/ai-review' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const languages = ['en', 'fr', 'nl'];
---
<header class="sticky top-0 z-50 border-b border-[#111111] bg-white/90 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-3 text-[#111111]">
      <svg
        class="h-8 w-8 text-accent"
        viewBox="0 0 32 32"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <rect x="2" y="2" width="28" height="28" stroke="currentColor" stroke-width="2" />
        <path d="M9 22V10l4 6 4-6v12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        <rect x="22" y="10" width="4" height="4" fill="#ff4f00" />
      </svg>
      <span class="text-lg font-bold">MSOIT</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-sm font-bold text-[#444444] transition-colors hover:text-accent-dark',
            currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
              ? 'text-accent-dark'
              : 'text-[#444444]',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="/contact"
        class="border border-[#111111] bg-accent px-4 py-2 text-sm font-bold text-[#111111] shadow-[4px_4px_0_#111111] transition-all hover:-translate-y-0.5 hover:shadow-[6px_6px_0_#111111]"
      >
        Book a Review
      </a>
      <div class="flex border border-[#111111]" aria-label="Language selector">
        {languages.map((lang) => (
          <button
            type="button"
            data-lang-toggle={lang}
            class="px-2.5 py-2 text-xs font-bold uppercase text-[#111111] transition-colors hover:bg-surface"
            aria-pressed={lang === 'en' ? 'true' : 'false'}
          >
            {lang}
          </button>
        ))}
      </div>
    </nav>

    <button
      id="mobile-menu-btn"
      class="flex items-center justify-center border border-[#111111] p-2 text-[#111111] hover:bg-surface md:hidden"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path id="menu-open" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        <path id="menu-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile Nav -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-[#111111] bg-white px-6 pb-6 pt-4 md:hidden"
    aria-label="Mobile navigation"
  >
    <div class="flex flex-col gap-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-base font-bold transition-colors',
            currentPath === item.href ? 'text-accent-dark' : 'text-[#444444] hover:text-accent-dark',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="/contact"
        class="mt-2 border border-[#111111] bg-accent px-4 py-3 text-center text-sm font-bold text-[#111111] transition-colors hover:bg-accent-light"
      >
        Book a Free IT Review
      </a>
      <div class="mt-2 grid grid-cols-3 border border-[#111111]" aria-label="Language selector">
        {languages.map((lang) => (
          <button
            type="button"
            data-lang-toggle={lang}
            class="px-3 py-3 text-sm font-bold uppercase text-[#111111] transition-colors hover:bg-surface"
            aria-pressed={lang === 'en' ? 'true' : 'false'}
          >
            {lang}
          </button>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open');
  const closeIcon = document.getElementById('menu-close');

  btn?.addEventListener('click', () => {
    const isExpanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!isExpanded));
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>
