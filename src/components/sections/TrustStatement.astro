---
const pillars = [
  ['Secure', 'Access, permissions, sharing and governance reviewed before tools are added.'],
  ['Automate', 'Routine admin translated into forms, approvals and managed workflows.'],
  ['Modernise', 'Microsoft 365, AI and web systems shaped around how the business actually works.'],
];
---
<section class="section-shell bg-white py-20">
  <div class="mx-auto max-w-7xl px-6" data-reveal>
    <div class="grid gap-10 lg:grid-cols-[1.05fr_1.4fr] lg:items-start">
      <p class="text-balance text-4xl font-bold leading-[0.98] text-[#111111] sm:text-5xl">
        Technology should make your business easier to run, not harder to understand.
      </p>
      <div>
        <p class="text-lg leading-8 text-[#444444]">
          MSOIT helps SMEs bring structure, security and automation to their IT environment so day-to-day work becomes clearer, safer and less dependent on manual workarounds.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-3" data-stagger>
          {pillars.map(([title, copy], index) => (
            <div data-stagger-item data-card class="border border-[#111111] bg-surface p-5">
              <p class="mb-6 text-sm font-bold text-accent">{String(index + 1).padStart(2, '0')}</p>
              <h3 class="text-lg font-bold text-[#111111]">{title}</h3>
              <p class="mt-2 text-sm leading-6 text-[#555555]">{copy}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
