---
import Button from '../ui/Button.astro';
---
<section class="relative overflow-hidden bg-navy-950 py-24">
  <div class="hero-orb pointer-events-none absolute left-1/2 top-0 h-80 w-80 -translate-x-1/2 rounded-full bg-accent/25 blur-3xl" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-3xl px-6 text-center" data-reveal>
    <h2 class="text-4xl font-medium tracking-[-0.045em] text-white sm:text-5xl">
      Ready to improve your business IT?
    </h2>
    <p class="mt-4 text-lg leading-relaxed text-blue-100">
      Book a free 30-minute IT review to discuss your current systems, security risks, manual processes and opportunities for automation or AI.
    </p>
    <div class="mt-10">
      <a
        href="/contact"
        class="inline-flex items-center justify-center rounded-lg bg-white px-8 py-4 text-lg font-semibold text-accent shadow-lg transition-colors hover:bg-blue-50"
      >
        Book a free 30-minute IT review
      </a>
    </div>
  </div>
</section>
