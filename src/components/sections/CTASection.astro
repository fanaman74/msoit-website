---
import Button from '../ui/Button.astro';
---
<section class="relative overflow-hidden border-t border-[#111111] bg-accent py-24">
  <div class="shape-ring hero-orb pointer-events-none absolute left-8 top-8 h-28 w-28" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-4xl px-6 text-center" data-reveal>
    <h2 class="text-balance text-5xl font-bold leading-[0.95] text-[#111111] sm:text-7xl">
      Ready to improve your business IT?
    </h2>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-[#111111]">
      Book a free 30-minute IT review to discuss your current systems, security risks, manual processes and opportunities for automation or AI in your Belgian SME.
    </p>
    <div class="mt-10">
      <a
        href="/contact"
        class="inline-flex items-center justify-center border border-[#111111] bg-white px-8 py-4 text-lg font-bold text-[#111111] shadow-[8px_8px_0_#111111] transition-all hover:-translate-y-0.5 hover:shadow-[11px_11px_0_#111111]"
      >
        Book a free 30-minute IT review
      </a>
    </div>
  </div>
</section>
