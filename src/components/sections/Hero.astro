---
import Button from '../ui/Button.astro';
---
<section class="relative isolate overflow-hidden bg-navy-950 py-24 sm:py-32 lg:py-36">
  <div class="surface-line pointer-events-none absolute inset-0" aria-hidden="true"></div>
  <div class="hero-orb pointer-events-none absolute -right-24 top-10 h-[28rem] w-[28rem] rounded-full bg-accent/20 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute bottom-0 left-0 h-px w-full bg-gradient-to-r from-transparent via-white/12 to-transparent" aria-hidden="true"></div>

  <div class="relative mx-auto grid max-w-7xl items-center gap-14 px-6 lg:grid-cols-[1fr_440px]">
    <div class="max-w-4xl">
      <div class="hero-kicker mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 text-xs font-medium uppercase tracking-[0.18em] text-slate-300">
        <span class="h-1.5 w-1.5 rounded-full bg-success"></span>
        MSOIT — Making Sense of IT
      </div>
      <h1 class="hero-title max-w-4xl text-5xl font-medium leading-[0.98] tracking-[-0.055em] text-[#f7f8f8] sm:text-6xl lg:text-7xl">
        Secure, automate and modernise your business IT
      </h1>
      <p class="hero-copy mt-7 max-w-2xl text-lg leading-8 text-slate-400 sm:text-xl">
        Senior IT consultancy for SMEs that need clearer systems, stronger security and practical automation — without vague AI hype or generic support packages.
      </p>
      <div class="hero-actions mt-10 flex flex-wrap gap-4">
        <Button href="/contact" variant="primary" size="lg">Book a free 30-minute IT review</Button>
        <Button href="/services" variant="secondary" size="lg">View services</Button>
      </div>
    </div>

    <div class="hero-panel premium-shadow hidden rounded-2xl border border-white/10 bg-white/[0.035] p-4 backdrop-blur md:block">
      <div class="rounded-xl border border-white/10 bg-navy-900/80 p-5">
        <div class="mb-5 flex items-center justify-between border-b border-white/10 pb-4">
          <div>
            <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Operational Review</p>
            <p class="mt-1 text-sm font-medium text-slate-200">Secure · Automate · Modernise</p>
          </div>
          <div class="rounded-full border border-success/30 bg-success/10 px-2.5 py-1 text-xs text-success">Live</div>
        </div>

        <div class="space-y-3">
          {[
            ['Access control', 'Permissions, MFA, sharing'],
            ['Workflow waste', 'Approvals, reminders, forms'],
            ['Document intelligence', 'Search, summarise, govern'],
            ['Modern presence', 'Website, forms, integrations'],
          ].map(([title, copy]) => (
            <div class="group rounded-lg border border-white/8 bg-white/[0.025] p-4 transition-colors hover:bg-white/[0.05]">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-sm font-medium text-slate-100">{title}</h3>
                  <p class="mt-1 text-xs leading-5 text-slate-500">{copy}</p>
                </div>
                <span class="mt-1 h-2 w-2 rounded-full bg-accent-light shadow-[0_0_18px_rgba(130,143,255,.7)]"></span>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-5 rounded-lg border border-accent/25 bg-accent/10 p-4">
          <p class="text-xs uppercase tracking-[0.18em] text-accent-light">Outcome</p>
          <p class="mt-2 text-sm leading-6 text-slate-300">A clear, prioritised plan for safer systems and less manual work.</p>
        </div>
      </div>
    </div>
  </div>
</section>
