---
import Button from '../ui/Button.astro';

const beltItems = ['Microsoft 365', 'Cybersecurity', 'Automation', 'AI systems', 'Websites', 'Governance'];
---
<section class="relative isolate overflow-hidden bg-white">
  <div class="surface-line pointer-events-none absolute inset-0" aria-hidden="true"></div>

  <!-- Animated orange tracer travelling along the background grid lines -->
  <svg class="pointer-events-none absolute inset-0 h-full w-full" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
    <path id="hero-grid-tracer" d="
      M 0 144
      H 432
      V 72
      H 720
      V 216
      H 576
      V 288
      H 864
      V 144
      H 1008
      V 360
      H 720
      V 432
      H 936
      V 288
      H 1152
    " fill="none" stroke="#f97316" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
      stroke-dasharray="60 9999"
      opacity="0.55">
      <animate attributeName="stroke-dashoffset" from="0" to="-1800" dur="9s" repeatCount="indefinite" calcMode="linear"/>
    </path>
    <path id="hero-grid-tracer-2" d="
      M 1152 360
      V 504
      H 864
      V 432
      H 648
      V 576
      H 432
      V 504
      H 216
      V 648
      H 0
    " fill="none" stroke="#f97316" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
      stroke-dasharray="60 9999"
      opacity="0.35">
      <animate attributeName="stroke-dashoffset" from="0" to="-1800" dur="12s" begin="4s" repeatCount="indefinite" calcMode="linear"/>
    </path>
  </svg>
  <div class="shape-ring hero-orb pointer-events-none absolute right-[-8rem] top-24 h-72 w-72" aria-hidden="true"></div>
  <div class="shape-square hero-shape pointer-events-none absolute left-6 top-28 h-10 w-10" aria-hidden="true"></div>

  <div class="relative mx-auto grid min-h-[calc(100vh-73px)] max-w-7xl items-center gap-12 px-6 py-16 lg:grid-cols-[1fr_460px] lg:py-20">
    <div class="max-w-4xl">
      <div class="hero-kicker mb-8 inline-flex items-center gap-3 border border-[#111111] bg-white px-4 py-2 text-sm font-bold text-[#111111]">
        <span class="h-2.5 w-2.5 bg-accent"></span>
        MSOIT — Making Sense of IT
      </div>
      <h1 class="hero-title text-balance max-w-5xl text-6xl font-bold leading-[0.86] text-[#111111] sm:text-7xl lg:text-8xl">
        Belgium IT services for secure, automated SMEs
      </h1>
      <p class="hero-copy mt-8 max-w-2xl text-lg leading-8 text-[#444444] sm:text-xl">
        Senior IT consultancy for Belgian SMEs that need clearer Microsoft 365 systems, stronger cybersecurity and practical automation — without vague AI hype or generic support packages.
      </p>
      <div class="hero-actions mt-10 flex flex-wrap gap-4">
        <Button href="/contact" variant="primary" size="lg">Book a free 30-minute IT review</Button>
        <Button href="/services" variant="secondary" size="lg">View services</Button>
      </div>
    </div>

    <div class="hero-panel premium-shadow hidden border border-[#111111] bg-surface p-4 md:block" data-panel>
      <div class="border border-[#111111] bg-white p-5">
        <div class="mb-5 flex items-center justify-between border-b border-[#111111] pb-4">
          <div>
            <p class="text-xs font-bold text-accent">Operational Review</p>
            <p class="mt-1 text-sm font-bold text-[#111111]">Secure. Automate. Modernise.</p>
          </div>
          <div class="border border-[#111111] bg-accent px-2.5 py-1 text-xs font-bold text-[#111111]">Live</div>
        </div>

        <div class="space-y-3">
          {[
            ['Access control', 'Permissions, MFA, sharing'],
            ['Workflow waste', 'Approvals, reminders, forms'],
            ['Document intelligence', 'Search, summarise, govern'],
            ['Modern presence', 'Website, forms, integrations'],
          ].map(([title, copy]) => (
            <div class="group border border-[#111111] bg-surface p-4 transition-transform duration-300 hover:-translate-x-1 hover:bg-white">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-sm font-bold text-[#111111]">{title}</h3>
                  <p class="mt-1 text-xs leading-5 text-[#555555]">{copy}</p>
                </div>
                <span class="mt-1 h-2 w-2 bg-accent"></span>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-5 border border-[#111111] bg-accent p-4">
          <p class="text-xs font-bold text-[#111111]">Outcome</p>
          <p class="mt-2 text-sm leading-6 text-[#111111]">A clear, prioritised plan for safer systems and less manual work.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {[...beltItems, ...beltItems].map((item) => (
        <span class="marquee__item">{item}</span>
      ))}
    </div>
  </div>
</section>
