---
import Button from '../ui/Button.astro';
import { Brain, FileSearch, Shield, Workflow, BookOpen, Map } from '@lucide/astro';

const deliverables = [
  'AI opportunity summary',
  'Prioritised use-case list',
  'Quick wins identified',
  'Risk and privacy considerations',
  'Recommended tools or platforms',
  'Practical AI roadmap',
  'Suggested next steps',
];
---
<section class="relative overflow-hidden bg-gradient-to-br from-accent-dark to-accent py-20">
  <!-- Subtle pattern -->
  <div class="pointer-events-none absolute inset-0 opacity-10" aria-hidden="true">
    <svg class="h-full w-full">
      <defs>
        <pattern id="dots" width="24" height="24" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1" fill="white" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dots)" />
    </svg>
  </div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Left: Copy -->
      <div>
        <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-blue-200">Featured Service</p>
        <h2 class="text-3xl font-bold text-white sm:text-4xl">AI Opportunity Review</h2>
        <p class="mt-4 text-lg leading-relaxed text-blue-100">
          Understand where AI can genuinely help your business before investing in tools or platforms.
        </p>
        <p class="mt-4 text-base leading-relaxed text-blue-100/80">
          Many businesses are interested in AI, but they are not sure where to start. The AI Opportunity Review helps your business identify realistic, practical and safe AI use cases — from document search and summarisation to process automation and Microsoft Copilot adoption.
        </p>
        <div class="mt-8">
          <Button href="/ai-review" variant="secondary" size="lg">
            Learn more about AI Opportunity Review
          </Button>
        </div>
      </div>

      <!-- Right: Deliverables -->
      <div class="rounded-2xl border border-white/20 bg-white/10 p-8 backdrop-blur-sm">
        <h3 class="mb-6 text-lg font-semibold text-white">What you receive</h3>
        <ul class="space-y-4">
          {deliverables.map((d) => (
            <li class="flex items-start gap-3 text-white">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-blue-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-base">{d}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
