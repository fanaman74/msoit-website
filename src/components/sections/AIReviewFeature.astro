---
import Button from '../ui/Button.astro';

const deliverables = [
  'AI opportunity summary',
  'Prioritised use-case list',
  'Quick wins identified',
  'Risk and privacy considerations',
  'Recommended tools or platforms',
  'Practical AI roadmap',
  'Suggested next steps',
];
---
<section class="section-shell bg-[#111111] py-24">
  <div class="relative mx-auto max-w-7xl px-6" data-reveal>
    <div class="grid items-stretch gap-6 lg:grid-cols-[1.1fr_.9fr]">
      <div class="border border-white bg-[#111111] p-8 sm:p-10">
        <p class="mb-5 text-sm font-bold text-accent">Featured Service</p>
        <h2 class="text-balance max-w-2xl text-5xl font-bold leading-[0.95] text-white sm:text-6xl">
          AI with a business case, not a buzzword.
        </h2>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-white/72">
          The AI Opportunity Review identifies realistic, safe use cases before you invest in tools. It focuses on document search, summarisation, process automation, Microsoft Copilot readiness and governance.
        </p>
        <div class="mt-9">
          <Button href="/ai-review" variant="primary" size="lg">Explore the AI Opportunity Review</Button>
        </div>
      </div>

      <div class="border border-white bg-white p-8 sm:p-10" data-stagger>
        <div class="mb-7 flex items-center justify-between gap-4">
          <h3 class="text-lg font-bold text-[#111111]">Review outputs</h3>
          <span class="border border-[#111111] px-3 py-1 text-xs font-bold text-[#111111]">Practical roadmap</span>
        </div>
        <ul class="space-y-3">
          {deliverables.map((d) => (
            <li data-stagger-item class="flex items-start gap-3 border border-[#111111] bg-surface p-3 text-[#111111]">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-sm leading-6">{d}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
