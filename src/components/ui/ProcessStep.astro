---
interface Props {
  step: number;
  title: string;
  description: string;
  last?: boolean;
}

const { step, title, description, last = false } = Astro.props;
---
<div data-stagger-item class="relative flex flex-col items-center text-center">
  <!-- Connector line (hidden on last item on desktop) -->
  {!last && (
    <div data-line class="absolute left-[calc(50%+1.75rem)] top-6 hidden h-px w-[calc(100%-1rem)] bg-white/12 lg:block" aria-hidden="true"></div>
  )}
  <!-- Step number -->
  <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-full border border-accent/35 bg-navy-950 shadow-[0_0_28px_rgba(94,106,210,.18)]">
    <span class="text-lg font-medium text-accent-light">{step}</span>
  </div>
  <h3 class="mt-4 text-base font-semibold text-white">{title}</h3>
  <p class="mt-2 max-w-xs text-sm leading-relaxed text-slate-400">{description}</p>
</div>
