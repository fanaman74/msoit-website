---
interface Props {
  step: number;
  title: string;
  description: string;
  last?: boolean;
}

const { step, title, description, last = false } = Astro.props;
---
<div class="relative flex flex-col items-center text-center">
  <!-- Connector line (hidden on last item on desktop) -->
  {!last && (
    <div class="absolute left-[calc(50%+1.75rem)] top-6 hidden h-0.5 w-[calc(100%-1rem)] bg-navy-600 lg:block" aria-hidden="true"></div>
  )}
  <!-- Step number -->
  <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-full border-2 border-accent bg-navy-900">
    <span class="text-lg font-bold text-accent">{step}</span>
  </div>
  <h3 class="mt-4 text-base font-semibold text-white">{title}</h3>
  <p class="mt-2 max-w-xs text-sm leading-relaxed text-slate-400">{description}</p>
</div>
