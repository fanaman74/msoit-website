---
interface Props {
  step: number;
  title: string;
  description: string;
  last?: boolean;
}

const { step, title, description, last = false } = Astro.props;
---
<div data-stagger-item data-card class="relative flex flex-col border border-[#111111] bg-white p-6">
  {!last && (
    <div data-line class="absolute left-full top-10 hidden h-px w-12 bg-[#111111] lg:block" aria-hidden="true"></div>
  )}
  <div class="relative z-10 flex h-14 w-14 items-center justify-center border border-[#111111] bg-accent">
    <span class="text-lg font-bold text-[#111111]">{String(step).padStart(2, '0')}</span>
  </div>
  <h3 class="mt-8 text-xl font-bold leading-tight text-[#111111]">{title}</h3>
  <p class="mt-3 text-sm leading-relaxed text-[#555555]">{description}</p>
</div>
