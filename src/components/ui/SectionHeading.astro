---
interface Props {
  heading: string;
  subheading?: string;
  align?: 'center' | 'left';
  dark?: boolean;
}

const { heading, subheading, align = 'center', dark = false } = Astro.props;
---
<div class:list={[align === 'center' ? 'text-center' : 'text-left']}>
  <p class:list={[
    'mb-4 text-sm font-bold text-accent',
    align === 'center' ? 'mx-auto' : '',
  ]}>MSOIT</p>
  <h2
    class:list={[
      'text-balance text-4xl font-bold leading-[0.95] sm:text-6xl',
      dark ? 'text-white' : 'text-[#111111]',
    ]}
  >
    {heading}
  </h2>
  {subheading && (
    <p
      class:list={[
        'mx-auto mt-5 max-w-2xl text-base leading-7 sm:text-lg',
        dark ? 'text-white/72' : 'text-[#444444]',
        align === 'center' ? 'mx-auto' : '',
      ]}
    >
      {subheading}
    </p>
  )}
</div>
