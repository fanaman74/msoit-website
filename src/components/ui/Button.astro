---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href: string;
  class?: string;
}

const { variant = 'primary', size = 'md', href, class: className } = Astro.props;

const base = 'inline-flex items-center justify-center font-semibold rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2';

const variants = {
  primary: 'bg-accent text-white hover:bg-accent-light',
  secondary: 'border-2 border-white/20 text-white hover:border-white/40 hover:bg-white/5',
  ghost: 'text-accent hover:text-accent-light underline-offset-4 hover:underline',
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};
---
<a
  href={href}
  class={`${base} ${variants[variant]} ${sizes[size]} ${className || ''}`}
>
  <slot />
</a>
