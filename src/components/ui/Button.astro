---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href: string;
  class?: string;
}

const { variant = 'primary', size = 'md', href, class: className } = Astro.props;

const base = 'inline-flex items-center justify-center rounded-md font-medium transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-navy-950';

const variants = {
  primary: 'bg-accent text-white shadow-[0_0_0_1px_rgba(255,255,255,.08),0_16px_34px_-18px_rgba(130,143,255,.9)] hover:-translate-y-0.5 hover:bg-accent-light',
  secondary: 'border border-white/10 bg-white/[0.03] text-slate-100 hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/[0.06]',
  ghost: 'text-accent hover:text-accent-light underline-offset-4 hover:underline',
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-5 py-3 text-sm',
  lg: 'px-6 py-3.5 text-base',
};
---
<a
  href={href}
  class={`${base} ${variants[variant]} ${sizes[size]} ${className || ''}`}
>
  <slot />
</a>
