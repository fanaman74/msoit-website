---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href: string;
  class?: string;
}

const { variant = 'primary', size = 'md', href, class: className } = Astro.props;

const base = 'inline-flex items-center justify-center border border-[#111111] font-bold transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-white';

const variants = {
  primary: 'bg-accent text-[#111111] shadow-[6px_6px_0_#111111] hover:-translate-y-0.5 hover:shadow-[9px_9px_0_#111111]',
  secondary: 'bg-white text-[#111111] hover:-translate-y-0.5 hover:bg-surface',
  ghost: 'border-transparent bg-transparent text-[#111111] underline decoration-accent decoration-2 underline-offset-4 hover:text-accent-dark',
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-5 py-3 text-sm',
  lg: 'px-6 py-3.5 text-base',
};
---
<a
  href={href}
  class={`${base} ${variants[variant]} ${sizes[size]} ${className || ''}`}
>
  <slot />
</a>
