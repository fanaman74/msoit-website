---
import { Shield } from '@lucide/astro';

interface Props {
  title: string;
  description: string;
  href: string;
  items?: string[];
  icon?: any;
}

const { title, description, href, items = [], icon: Icon } = Astro.props;
---
<div data-stagger-item data-card class="group relative flex min-h-[25rem] flex-col overflow-hidden border border-[#111111] bg-white p-7 transition-all duration-300 hover:-translate-y-1 hover:shadow-[10px_10px_0_#ff4f00]">
  <div class="mb-8 flex h-14 w-14 items-center justify-center border border-[#111111] bg-accent">
    {Icon ? (
      <Icon class="h-6 w-6 text-[#111111]" stroke-width="1.7" />
    ) : (
      <Shield class="h-6 w-6 text-[#111111]" stroke-width="1.7" />
    )}
  </div>
  <h3 class="mb-3 text-2xl font-bold leading-tight text-[#111111]">{title}</h3>
  <p class="mb-5 flex-1 text-sm leading-6 text-[#555555]">{description}</p>
  {items.length > 0 && (
    <ul class="mb-6 space-y-2.5">
      {items.map((item) => (
        <li class="flex items-start gap-2 text-sm text-[#444444]">
          <svg class="mt-1 h-3.5 w-3.5 flex-shrink-0 text-accent" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  )}
  <a
    href={href}
    class="mt-auto inline-flex items-center text-sm font-bold text-[#111111] underline decoration-accent decoration-2 underline-offset-4 transition-colors hover:text-accent-dark"
  >
    Learn more
    <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </a>
</div>
