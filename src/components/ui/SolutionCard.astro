---
interface Props {
  title: string;
  description: string;
  features?: string[];
}

const { title, description, features = [] } = Astro.props;
---
<div class="rounded-xl border border-slate-200 bg-white p-8 transition-shadow hover:shadow-lg">
  <h3 class="mb-3 text-lg font-semibold text-slate-900">{title}</h3>
  <p class="mb-5 text-sm leading-relaxed text-slate-600">{description}</p>
  {features.length > 0 && (
    <ul class="space-y-2">
      {features.map((f) => (
        <li class="flex items-start gap-2 text-sm text-slate-600">
          <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span>{f}</span>
        </li>
      ))}
    </ul>
  )}
</div>
