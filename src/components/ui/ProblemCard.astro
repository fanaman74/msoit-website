---
import { AlertCircle } from '@lucide/astro';

interface Props {
  title: string;
  description: string;
  icon?: any;
}

const { title, description, icon: Icon } = Astro.props;
---
<div data-stagger-item class="flex gap-4 rounded-xl border border-white/8 bg-white/[0.035] p-6 backdrop-blur transition-colors duration-300 hover:bg-white/[0.055]">
  <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg border border-accent/20 bg-accent/10">
    {Icon ? (
      <Icon class="h-5 w-5 text-accent-light" stroke-width="1.8" />
    ) : (
      <AlertCircle class="h-5 w-5 text-accent-light" stroke-width="1.8" />
    )}
  </div>
  <div>
    <h3 class="mb-2 text-base font-semibold text-white">{title}</h3>
    <p class="text-sm leading-6 text-slate-300">{description}</p>
  </div>
</div>
