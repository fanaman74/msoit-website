---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/sections/CTASection.astro';
import WhyWorkWithMe from '../components/sections/WhyWorkWithMe.astro';
import Process from '../components/sections/Process.astro';
---

<Layout
  title="About MSOIT Belgian IT Consultancy"
  description="Senior IT professional helping Belgian SMEs with secure systems, automation, Microsoft 365, AI and modern cloud solutions."
  keywords={['MSOIT Belgium', 'Belgium IT consultant', 'SME technology consultant Belgium', 'Microsoft 365 SME Belgium']}
>
  <section class="section-shell bg-white py-20">
    <div class="surface-line pointer-events-none absolute inset-0" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-7xl px-6" data-reveal>
      <p class="mb-5 text-sm font-bold text-accent">About MSOIT</p>
      <h1 class="text-balance max-w-5xl text-6xl font-bold leading-[0.88] text-[#111111] sm:text-8xl">Making sense of IT for SMEs.</h1>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-[#444444]">Senior IT expertise for Belgian SMEs that need secure, modern and practical technology solutions.</p>
    </div>
  </section>

  <section class="section-shell bg-surface py-20">
    <div class="relative mx-auto grid max-w-7xl gap-10 px-6 lg:grid-cols-[0.65fr_1fr]" data-reveal>
      <div class="border border-[#111111] bg-accent p-6">
        <p class="text-sm font-bold text-[#111111]">Approach</p>
        <p class="mt-10 text-3xl font-bold leading-tight text-[#111111]">Understand the business problem first, then design the right technical solution.</p>
      </div>
      <div class="space-y-6 border border-[#111111] bg-white p-6 text-lg leading-relaxed text-[#444444] lg:p-8">
        <p>I help small and medium-sized businesses improve their IT systems, secure their data, automate manual work and adopt modern cloud and AI solutions.</p>
        <p>My background is in senior IT work within complex institutional environments, where reliability, security, documentation, governance and service quality are essential. This experience allows me to bring structured, professional IT thinking to SMEs that need practical support without unnecessary complexity.</p>
        <p>My approach is simple: understand the business problem first, then design the right technical solution. Whether the need is Microsoft 365, cybersecurity, automation, AI document management or a modern website, the focus is always on making the business more secure, organised and efficient.</p>
      </div>
    </div>
  </section>

  <WhyWorkWithMe />
  <Process />
  <CTASection />
</Layout>
