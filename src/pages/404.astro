---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found" description="The page you are looking for could not be found.">
  <section class="section-shell bg-white py-32">
    <div class="surface-line pointer-events-none absolute inset-0" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-3xl px-6 text-center" data-reveal>
      <p class="text-8xl font-bold text-accent">404</p>
      <h1 class="mt-4 text-5xl font-bold text-[#111111]">Page not found</h1>
      <p class="mt-4 text-lg text-[#444444]">The page you are looking for does not exist or has been moved.</p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/" class="inline-flex items-center border border-[#111111] bg-accent px-6 py-3 font-bold text-[#111111] shadow-[6px_6px_0_#111111] transition-all hover:-translate-y-0.5">Back to Home</a>
        <a href="/services" class="inline-flex items-center border border-[#111111] bg-white px-6 py-3 font-bold text-[#111111] transition-colors hover:bg-surface">View Services</a>
        <a href="/contact" class="inline-flex items-center border border-[#111111] bg-white px-6 py-3 font-bold text-[#111111] transition-colors hover:bg-surface">Contact Us</a>
      </div>
    </div>
  </section>
</Layout>
