---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found" description="The page you are looking for could not be found.">
  <section class="bg-navy-900 py-32">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <p class="text-6xl font-bold text-accent">404</p>
      <h1 class="mt-4 text-3xl font-bold text-white">Page not found</h1>
      <p class="mt-4 text-lg text-slate-400">The page you are looking for does not exist or has been moved.</p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a href="/" class="inline-flex items-center rounded-lg bg-accent px-6 py-3 font-semibold text-white hover:bg-accent-light transition-colors">Back to Home</a>
        <a href="/services" class="inline-flex items-center rounded-lg border-2 border-white/20 px-6 py-3 font-semibold text-white hover:border-white/40 transition-colors">View Services</a>
        <a href="/contact" class="inline-flex items-center rounded-lg border-2 border-white/20 px-6 py-3 font-semibold text-white hover:border-white/40 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>
</Layout>
