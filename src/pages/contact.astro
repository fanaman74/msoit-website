---
import Layout from '../layouts/Layout.astro';

const areas = [
  'Microsoft 365',
  'Cybersecurity',
  'Automation',
  'AI Opportunity Review',
  'AI Document Management',
  'Website',
  'General IT Review',
];
---

<Layout title="Contact" description="Book a free 30-minute IT review to discuss your systems, security, automation and AI opportunities.">
  <!-- Hero -->
  <section class="bg-navy-900 py-20">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h1 class="text-4xl font-bold text-white sm:text-5xl">Book a Free IT Review</h1>
      <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">Use the form below to request a free 30-minute review of your current IT systems, security concerns, manual processes, website or AI opportunities.</p>
    </div>
  </section>

  <!-- Form -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-2xl px-6">
      <form id="contact-form" class="space-y-6">
        <div id="form-status" class="hidden rounded-lg p-4 text-sm font-medium"></div>
        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700">Name <span class="text-red-500">*</span></label>
            <input type="text" id="name" name="name" required class="mt-1 w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none" />
          </div>
          <div>
            <label for="company" class="block text-sm font-medium text-slate-700">Company</label>
            <input type="text" id="company" name="company" class="mt-1 w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none" />
          </div>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700">Email <span class="text-red-500">*</span></label>
            <input type="email" id="email" name="email" required class="mt-1 w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-slate-700">Phone</label>
            <input type="tel" id="phone" name="phone" class="mt-1 w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none" />
          </div>
        </div>

        <div>
          <label for="area" class="block text-sm font-medium text-slate-700">Area of Interest</label>
          <select id="area" name="area" class="mt-1 w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none bg-white">
            <option value="">Select an area</option>
            {areas.map((a) => (
              <option value={a}>{a}</option>
            ))}
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-slate-700">Message</label>
          <textarea id="message" name="message" rows={5} class="mt-1 w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none" placeholder="Tell me about your current systems, challenges or goals..."></textarea>
        </div>

        <button type="submit" id="submit-btn" class="w-full rounded-lg bg-accent px-8 py-4 text-lg font-semibold text-white transition-colors hover:bg-accent-light focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed">
          Book a free 30-minute IT review
        </button>
        <p class="text-center text-sm text-slate-500">This is a practical discussion to understand where technology can help your business.</p>
      </form>

      <script is:inline>
        document.getElementById('contact-form').addEventListener('submit', async (e) => {
          e.preventDefault();
          const form = e.target;
          const btn = document.getElementById('submit-btn');
          const status = document.getElementById('form-status');

          btn.disabled = true;
          btn.textContent = 'Sending...';
          status.className = 'hidden';

          try {
            const formData = new FormData(form);
            const payload = Object.fromEntries(formData.entries());
            const res = await fetch('/api/contact', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
            const data = await res.json();

            if (data.success) {
              status.className = 'rounded-lg p-4 text-sm font-medium bg-green-50 text-green-800 border border-green-200';
              status.textContent = data.message;
              form.reset();
            } else {
              status.className = 'rounded-lg p-4 text-sm font-medium bg-red-50 text-red-800 border border-red-200';
              status.textContent = data.error || 'Something went wrong.';
            }
          } catch (err) {
            status.className = 'rounded-lg p-4 text-sm font-medium bg-red-50 text-red-800 border border-red-200';
            status.textContent = 'Network error. Please try again or email directly.';
          } finally {
            btn.disabled = false;
            btn.textContent = 'Book a free 30-minute IT review';
            status.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        });
      </script>
    </div>
  </section>
</Layout>
