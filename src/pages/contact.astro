---
import Layout from '../layouts/Layout.astro';

const areas = [
  'Microsoft 365',
  'Cybersecurity',
  'Automation',
  'AI Opportunity Review',
  'AI Document Management',
  'Website',
  'General IT Review',
];

const inputClass = 'mt-2 w-full border border-[#111111] bg-white px-4 py-3 text-[#111111] placeholder-[#777777] focus:border-accent focus:ring-2 focus:ring-accent/25 focus:outline-none';
const labelClass = 'block text-sm font-bold text-[#111111]';
---

<Layout
  title="Contact MSOIT for a Belgium SME IT Review"
  description="Book a free 30-minute IT review for your Belgian SME to discuss Microsoft 365, cybersecurity, automation, AI and website opportunities."
  keywords={['free IT review Belgium', 'SME IT consultant Belgium', 'Microsoft 365 review Belgium', 'cybersecurity review Belgium']}
>
  <section class="section-shell bg-white py-20">
    <div class="surface-line pointer-events-none absolute inset-0" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-7xl px-6" data-reveal>
      <p class="mb-5 text-sm font-bold text-accent">Contact</p>
      <h1 class="text-balance max-w-5xl text-6xl font-bold leading-[0.88] text-[#111111] sm:text-8xl">Book a free IT review.</h1>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-[#444444]">Use the form below to request a free 30-minute review of your Belgian SME's current IT systems, security concerns, manual processes, website or AI opportunities.</p>
    </div>
  </section>

  <section class="section-shell bg-surface py-20">
    <div class="relative mx-auto grid max-w-7xl gap-8 px-6 lg:grid-cols-[0.7fr_1fr]" data-reveal>
      <aside class="border border-[#111111] bg-accent p-6">
        <p class="text-sm font-bold text-[#111111]">What to expect</p>
        <ul class="mt-10 space-y-4 text-lg font-bold leading-tight text-[#111111]">
          <li>Discuss your current systems and risks.</li>
          <li>Identify practical automation or AI opportunities.</li>
          <li>Leave with clearer next steps.</li>
        </ul>
      </aside>

      <form id="contact-form" class="border border-[#111111] bg-white p-6 lg:p-8">
        <div id="form-status" class="mb-6 hidden border border-[#111111] p-4 text-sm font-bold"></div>
        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label for="name" class={labelClass}>Name <span class="text-accent">*</span></label>
            <input type="text" id="name" name="name" required class={inputClass} />
          </div>
          <div>
            <label for="company" class={labelClass}>Company</label>
            <input type="text" id="company" name="company" class={inputClass} />
          </div>
        </div>

        <div class="mt-6 grid gap-6 sm:grid-cols-2">
          <div>
            <label for="email" class={labelClass}>Email <span class="text-accent">*</span></label>
            <input type="email" id="email" name="email" required class={inputClass} />
          </div>
          <div>
            <label for="phone" class={labelClass}>Phone</label>
            <input type="tel" id="phone" name="phone" class={inputClass} />
          </div>
        </div>

        <div class="mt-6">
          <label for="area" class={labelClass}>Area of Interest</label>
          <select id="area" name="area" class={inputClass}>
            <option value="">Select an area</option>
            {areas.map((a) => (
              <option value={a}>{a}</option>
            ))}
          </select>
        </div>

        <div class="mt-6">
          <label for="message" class={labelClass}>Message</label>
          <textarea id="message" name="message" rows={5} class={inputClass} placeholder="Tell me about your current systems, challenges or goals..."></textarea>
        </div>

        <button type="submit" id="submit-btn" class="mt-6 w-full border border-[#111111] bg-accent px-8 py-4 text-lg font-bold text-[#111111] shadow-[6px_6px_0_#111111] transition-all hover:-translate-y-0.5 hover:shadow-[9px_9px_0_#111111] focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:outline-none disabled:cursor-not-allowed disabled:opacity-50">
          Book a free 30-minute IT review
        </button>
        <p class="mt-4 text-sm text-[#666666]">
          We will handle your details as described in our <a href="/privacy" class="text-accent underline hover:no-underline">Privacy Policy</a>. We use them only to respond to your enquiry.
        </p>
        <p class="mt-4 text-center text-sm text-[#555555]">This is a practical discussion to understand where technology can help your business.</p>
      </form>

      <script is:inline>
        document.getElementById('contact-form').addEventListener('submit', async (e) => {
          e.preventDefault();
          const form = e.target;
          const btn = document.getElementById('submit-btn');
          const status = document.getElementById('form-status');
          const translate = window.msoitTranslate || ((value) => value);

          btn.disabled = true;
          btn.textContent = translate('Sending...');
          status.className = 'mb-6 hidden border border-[#111111] p-4 text-sm font-bold';

          try {
            const formData = new FormData(form);
            const payload = Object.fromEntries(formData.entries());
            const params = new URLSearchParams(window.location.search);
            payload.language = localStorage.getItem('msoit:lang') || 'en';
            payload.page_url = window.location.href;
            payload.referrer = document.referrer;
            ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'].forEach((key) => {
              payload[key] = params.get(key) || '';
            });
            const res = await fetch('/api/contact', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
            const data = await res.json();

            if (data.success) {
              status.className = 'mb-6 border border-[#111111] bg-green-50 p-4 text-sm font-bold text-green-800';
              status.textContent = translate(data.message);
              form.reset();
            } else {
              status.className = 'mb-6 border border-[#111111] bg-red-50 p-4 text-sm font-bold text-red-800';
              status.textContent = translate(data.error || 'Something went wrong.');
            }
          } catch (err) {
            status.className = 'mb-6 border border-[#111111] bg-red-50 p-4 text-sm font-bold text-red-800';
            status.textContent = translate('Network error. Please try again or email directly.');
          } finally {
            btn.disabled = false;
            btn.textContent = translate('Book a free 30-minute IT review');
            status.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        });
      </script>
    </div>
  </section>
</Layout>
