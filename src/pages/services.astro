---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/sections/CTASection.astro';

const services = [
  {
    id: 'microsoft-365',
    title: 'Microsoft 365 & Cloud Productivity',
    description: 'Modernise how your team works with secure Microsoft 365 environments, structured file management, better collaboration and clear governance.',
    outcome: 'A cleaner, more secure and more organised Microsoft 365 environment that supports daily work.',
    items: ['Microsoft 365 setup and optimisation','SharePoint document libraries','Teams structure and governance','OneDrive and file migration','Exchange and business email','User access and permissions review','Secure sharing configuration','File structure redesign','Microsoft 365 governance documentation','Collaboration improvements'],
  },
  {
    id: 'cybersecurity',
    title: 'Cybersecurity & IT Governance',
    description: 'Protect your business with practical cybersecurity improvements, secure access management and clear IT policies designed for SMEs.',
    outcome: 'Understand your main IT security risks and receive practical steps to reduce exposure and protect business information.',
    items: ['Cybersecurity review','Microsoft 365 security hardening','Multi-factor authentication review','Conditional access recommendations','Access control and permissions review','Data protection and backup review','Email security review','IT policies and governance documentation','Security awareness support','Risk prioritisation'],
  },
  {
    id: 'automation',
    title: 'Business Automation',
    description: 'Reduce manual work by automating repetitive business processes, approvals, document handling and internal workflows.',
    outcome: 'Save time, reduce errors and gain better visibility over processes previously managed through email or spreadsheets.',
    items: ['Power Automate workflows','Power Apps business applications','Approval systems','Forms and data collection','Automated reminders and notifications','Excel-to-app modernisation','Internal process dashboards','Document workflow automation','Task tracking systems','Simple CRM or case management','Operational reporting dashboards'],
  },
  {
    id: 'ai-strategy',
    title: 'AI Strategy & Opportunity Review',
    description: 'AI can save your business time, but only when it is applied to the right problems. I help SMEs understand where AI can genuinely improve their operations, from document search and summarisation to process automation, customer support, internal knowledge systems and Microsoft Copilot adoption.',
    outcome: 'A clear understanding of where AI can help, with a prioritised roadmap instead of vague ideas or unnecessary software purchases.',
    items: ['AI readiness review','Identification of practical AI use cases','Review of manual processes that could benefit from AI','Document and knowledge-management opportunity review','Microsoft Copilot readiness and adoption planning','AI risk, privacy and governance considerations','Staff awareness and training sessions','Prioritised AI roadmap','Tool and platform recommendations','Guidance on Copilot, custom AI tools or document intelligence'],
  },
  {
    id: 'ai-documents',
    title: 'AI Document & Knowledge Systems',
    description: 'Build secure AI-powered document systems that help your business search, summarise and understand large volumes of files.',
    outcome: 'Find, understand and reuse your own information more effectively.',
    items: ['AI document management systems','Semantic search across PDFs, Word, emails','Document summarisation','Legal and HR document analysis','Internal knowledge bases','AI-assisted file classification','Secure searchable archives','Document metadata extraction','Searchable policy and procedure libraries'],
  },
  {
    id: 'websites',
    title: 'Websites & Digital Presence',
    description: 'Create a professional, modern website that presents your business clearly, builds trust and connects with your wider digital systems.',
    outcome: 'A modern, credible online presence that supports lead generation and business growth.',
    items: ['Business websites','Service landing pages','Website modernisation','Contact forms and booking flows','SEO-ready structure','Secure hosting guidance','Integration with Microsoft 365','Integration with CRM or automation tools','Professional service pages','Basic analytics setup'],
  },
];
---

<Layout
  title="IT Services for Belgian SMEs"
  description="Microsoft 365, cybersecurity, automation, AI consulting, document management and website services for SMEs in Belgium."
  keywords={['IT services Belgium', 'SME IT support Belgium', 'Microsoft 365 Belgium', 'cybersecurity consultant Belgium', 'AI document management Belgium', 'business automation Belgium']}
>
  <section class="section-shell bg-white py-20">
    <div class="surface-line pointer-events-none absolute inset-0" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-7xl px-6" data-reveal>
      <p class="mb-5 text-sm font-bold text-accent">Services</p>
      <h1 class="text-balance max-w-5xl text-6xl font-bold leading-[0.88] text-[#111111] sm:text-8xl">Focused IT services for Belgian SMEs.</h1>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-[#444444]">I help SMEs across Belgium improve how they manage technology, documents, security, workflows and AI adoption.</p>
    </div>
  </section>

  <section class="section-shell bg-surface py-20">
    <div class="relative mx-auto max-w-7xl space-y-6 px-6">
      {services.map((service, index) => (
        <article id={service.id} data-reveal class="grid gap-8 border border-[#111111] bg-white p-6 lg:grid-cols-[0.7fr_1fr] lg:p-8">
          <div>
            <p class="mb-6 text-sm font-bold text-accent">{String(index + 1).padStart(2, '0')}</p>
            <h2 class="text-3xl font-bold leading-tight text-[#111111]">{service.title}</h2>
            <p class="mt-5 leading-7 text-[#444444]">{service.description}</p>
            <p class="mt-5 border-l-4 border-accent pl-4 font-bold leading-7 text-[#111111]">Outcome: {service.outcome}</p>
          </div>
          <ul class="grid gap-3 sm:grid-cols-2" data-stagger>
            {service.items.map((item) => (
              <li data-stagger-item class="flex items-start gap-3 border border-[#111111] bg-surface p-3 text-sm text-[#444444]">
                <span class="mt-1 h-2 w-2 flex-shrink-0 bg-accent"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <CTASection />
</Layout>
