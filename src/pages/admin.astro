---
import '../styles/global.css';

const COOKIE_NAME = 'msoit_admin';
const TOKEN = Buffer.from('Manchester74!!!').toString('base64');

const isAuthed = Astro.cookies.get(COOKIE_NAME)?.value === TOKEN;
const showError = Astro.url.searchParams.get('error') === '1';

let leads: Record<string, unknown>[] = [];
let repliesByLead: Record<string, { subject: string; message: string; sent_at: string; direction: string }[]> = {};

function stripQuoted(text: string): string {
  return text.replace(/\r\n/g, '\n').split(/\n(?=On .+wrote:)/)[0].trim();
}

if (isAuthed) {
  const supabaseUrl = import.meta.env.SUPABASE_URL || process.env.SUPABASE_URL;
  const serviceRoleKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY || process.env.SUPABASE_SERVICE_ROLE_KEY;

  if (supabaseUrl && serviceRoleKey) {
    const headers = {
      apikey: serviceRoleKey,
      Authorization: `Bearer ${serviceRoleKey}`,
      'Content-Type': 'application/json',
    };
    const base = supabaseUrl.replace(/\/$/, '');

    const [leadsRes, repliesRes] = await Promise.all([
      fetch(`${base}/rest/v1/lead_submissions?order=submitted_at.desc&limit=200`, { headers }),
      fetch(`${base}/rest/v1/lead_replies?order=sent_at.asc&limit=1000`, { headers }),
    ]);

    if (leadsRes.ok) leads = await leadsRes.json();

    if (repliesRes.ok) {
      const allReplies: { lead_id: string; subject: string; message: string; sent_at: string; direction: string }[] = await repliesRes.json();
      for (const r of allReplies) {
        if (!repliesByLead[r.lead_id]) repliesByLead[r.lead_id] = [];
        repliesByLead[r.lead_id].push({ subject: r.subject, message: r.message, sent_at: r.sent_at, direction: r.direction || 'outbound' });
      }
    }
  }
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — MSOIT</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; background: #f5f5f5; color: #111; min-height: 100vh; }

    /* Login */
    .login-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .login-card { background: #fff; border: 1px solid #111; padding: 2.5rem; width: 100%; max-width: 380px; }
    .login-card h1 { font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; }
    .login-card label { display: block; font-size: 0.75rem; font-weight: 600; margin-bottom: 0.4rem; }
    .login-card input[type="password"] {
      width: 100%; border: 1px solid #111; padding: 0.6rem 0.75rem;
      font-size: 0.9rem; outline: none; font-family: inherit;
    }
    .login-card input[type="password"]:focus { outline: 2px solid #f97316; outline-offset: -2px; }
    .login-card button {
      margin-top: 1rem; width: 100%; background: #111; color: #fff;
      border: none; padding: 0.7rem; font-size: 0.9rem; font-weight: 600;
      cursor: pointer; font-family: inherit;
    }
    .login-card button:hover { background: #f97316; color: #111; }
    .error-msg { margin-top: 0.75rem; font-size: 0.8rem; color: #dc2626; font-weight: 500; }

    /* Admin dashboard */
    .admin-wrap { max-width: 1400px; margin: 0 auto; padding: 2rem 1.5rem; }
    .admin-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; border-bottom: 2px solid #111; padding-bottom: 1rem; }
    .admin-header h1 { font-size: 1.4rem; font-weight: 700; }
    .admin-header span { font-size: 0.8rem; color: #555; }
    .badge { display: inline-block; background: #f97316; color: #111; font-size: 0.7rem; font-weight: 700; padding: 0.2rem 0.5rem; margin-left: 0.5rem; }
    .empty { text-align: center; padding: 3rem; color: #777; font-size: 0.95rem; }

    /* Table */
    .table-wrap { overflow-x: auto; background: #fff; border: 1px solid #111; }
    table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    thead { background: #111; color: #fff; }
    th { padding: 0.65rem 0.85rem; text-align: left; font-weight: 600; white-space: nowrap; }
    td { padding: 0.65rem 0.85rem; border-bottom: 1px solid #e5e5e5; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #fafafa; }
    .tag { display: inline-block; background: #f0f0f0; border: 1px solid #ddd; font-size: 0.7rem; padding: 0.15rem 0.4rem; border-radius: 2px; }
    .tag-area { background: #fff7ed; border-color: #fed7aa; color: #9a3412; }
    .mono { font-family: monospace; font-size: 0.75rem; color: #555; }
    .date { white-space: nowrap; color: #555; font-size: 0.75rem; }

    /* Status select */
    .status-select {
      border: 1px solid #ddd; padding: 0.25rem 0.4rem; font-size: 0.75rem;
      font-family: inherit; cursor: pointer; background: #fff; border-radius: 2px;
      transition: border-color 0.15s;
    }
    .status-select:focus { outline: 2px solid #f97316; outline-offset: -2px; }
    .status-select[data-status="new"]       { background: #eff6ff; border-color: #93c5fd; color: #1d4ed8; }
    .status-select[data-status="contacted"] { background: #fefce8; border-color: #fde047; color: #854d0e; }
    .status-select[data-status="closed"]    { background: #f0fdf4; border-color: #86efac; color: #166534; }
    .status-select.saving { opacity: 0.5; }

    /* Reply history */
    .reply-history { margin-top: 6px; }
    .reply-bubble {
      background: #f0f7ff; border-left: 3px solid #f97316; padding: 6px 10px;
      margin-bottom: 4px; font-size: 0.75rem; line-height: 1.5;
    }
    .reply-bubble--inbound { background: #f9f9f9; border-left-color: #aaa; }
    .reply-bubble-subject { font-weight: 700; color: #111; margin-bottom: 2px; }
    .reply-bubble-meta { font-size: 0.68rem; color: #888; margin-top: 3px; }
    .reply-bubble-body { color: #333; white-space: pre-wrap; }
    .history-toggle { font-size: 0.7rem; color: #f97316; cursor: pointer; background: none; border: none; font-family: inherit; padding: 0; text-decoration: underline; }

    /* Reply button */
    .reply-btn {
      font-size: 0.72rem; font-weight: 600; font-family: inherit;
      background: #fff; border: 1px solid #111; padding: 0.25rem 0.6rem;
      cursor: pointer; white-space: nowrap; transition: background 0.15s;
    }
    .reply-btn:hover { background: #f97316; color: #fff; border-color: #f97316; }
    .delete-btn {
      font-size: 0.72rem; font-weight: 600; font-family: inherit;
      background: #fff; border: 1px solid #ddd; color: #999; padding: 0.25rem 0.6rem;
      cursor: pointer; white-space: nowrap; transition: all 0.15s; margin-top: 4px; display: block; width: 100%;
    }
    .delete-btn:hover { background: #dc2626; color: #fff; border-color: #dc2626; }

    /* Reply modal */
    .modal-overlay {
      display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5);
      z-index: 100; align-items: center; justify-content: center; padding: 1rem;
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: #fff; border: 1px solid #111; width: 100%; max-width: 560px;
      max-height: 90vh; overflow-y: auto;
    }
    .modal-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 1.25rem; border-bottom: 1px solid #111; background: #111; color: #fff;
    }
    .modal-header h2 { font-size: 0.9rem; font-weight: 700; }
    .modal-close {
      background: none; border: none; color: #fff; font-size: 1.2rem;
      cursor: pointer; line-height: 1; padding: 0;
    }
    .modal-body { padding: 1.25rem; }
    .modal-field { margin-bottom: 1rem; }
    .modal-field label { display: block; font-size: 0.72rem; font-weight: 700; margin-bottom: 0.3rem; text-transform: uppercase; letter-spacing: .04em; }
    .modal-field input, .modal-field textarea {
      width: 100%; border: 1px solid #ccc; padding: 0.55rem 0.75rem;
      font-size: 0.85rem; font-family: inherit; outline: none;
    }
    .modal-field input:focus, .modal-field textarea:focus { border-color: #f97316; outline: 2px solid #f97316; outline-offset: -2px; }
    .modal-field textarea { resize: vertical; min-height: 160px; }
    .modal-footer { display: flex; gap: 0.75rem; justify-content: flex-end; padding: 1rem 1.25rem; border-top: 1px solid #eee; }
    .btn-send {
      background: #111; color: #fff; border: none; padding: 0.6rem 1.25rem;
      font-size: 0.85rem; font-weight: 700; cursor: pointer; font-family: inherit;
    }
    .btn-send:hover { background: #f97316; }
    .btn-send:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-cancel {
      background: #fff; color: #111; border: 1px solid #ccc; padding: 0.6rem 1.25rem;
      font-size: 0.85rem; font-weight: 600; cursor: pointer; font-family: inherit;
    }
    .send-status { font-size: 0.8rem; font-weight: 600; padding: 0.5rem 0; }
    .send-status.ok { color: #166534; }
    .send-status.err { color: #dc2626; }
  </style>
</head>
<body>

{!isAuthed ? (
  <div class="login-wrap">
    <div class="login-card">
      <h1>MSOIT Admin</h1>
      <form method="POST" action="/api/admin-login">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required autofocus />
        {showError && <p class="error-msg">Incorrect password. Try again.</p>}
        <button type="submit">Sign in</button>
      </form>
    </div>
  </div>
) : (
  <div class="admin-wrap">
    <div class="admin-header">
      <h1>
        Lead Submissions
        <span class="badge">{leads.length}</span>
      </h1>
      <span>MSOIT Admin · <a href="/api/admin-logout" style="color:#f97316;text-decoration:none;font-weight:600;">Sign out</a></span>
    </div>

    {leads.length === 0 ? (
      <p class="empty">No leads yet. They will appear here once the contact form is submitted.</p>
    ) : (
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Status</th>
              <th>Reply</th>
              <th>Date</th>
              <th>Name</th>
              <th>Company</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Area</th>
              <th>Message</th>
              <th>Lang</th>
              <th>Source</th>
            </tr>
          </thead>
          <tbody>
            {leads.map((lead) => (
              <tr>
                <td>
                  <select
                    class="status-select"
                    data-id={lead.id as string}
                    data-status={lead.status as string || 'new'}
                  >
                    <option value="new"       selected={(lead.status || 'new') === 'new'}>New</option>
                    <option value="contacted" selected={(lead.status as string) === 'contacted'}>Contacted</option>
                    <option value="closed"    selected={(lead.status as string) === 'closed'}>Closed</option>
                  </select>
                </td>
                <td>
                  <button
                    class="reply-btn"
                    data-id={lead.id as string}
                    data-email={lead.email as string}
                    data-name={lead.name as string}
                    data-area={lead.area as string || ''}
                    data-last-subject={(() => {
                      const replies = repliesByLead[lead.id as string] || [];
                      const lastInbound = [...replies].reverse().find(r => r.direction === 'inbound');
                      return lastInbound ? lastInbound.subject : '';
                    })()}
                  >Reply</button>
                  <button
                    class="delete-btn"
                    data-id={lead.id as string}
                  >Delete</button>
                </td>
                <td class="date">
                  {new Date(lead.submitted_at as string).toLocaleDateString('en-GB', {
                    day: '2-digit', month: 'short', year: 'numeric',
                    hour: '2-digit', minute: '2-digit',
                  })}
                </td>
                <td><strong>{lead.name as string}</strong></td>
                <td>{lead.company as string || '—'}</td>
                <td>
                  <a href={`mailto:${lead.email}`} style="color:#f97316;">{lead.email as string}</a>
                  {(() => {
                    const replies = repliesByLead[lead.id as string] || [];
                    const hasThread = !!(lead.message || replies.length);
                    if (!hasThread) return null;
                    const label = replies.length ? `${replies.length} ${replies.length === 1 ? 'reply' : 'replies'} sent` : 'View message';
                    return (
                      <div class="reply-history">
                        <button class="history-toggle" onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='none'?'block':'none'">
                          {label}
                        </button>
                        <div style="display:none;margin-top:4px;">
                          {lead.message && (
                            <div class="reply-bubble reply-bubble--inbound">
                              <div class="reply-bubble-subject">Initial message</div>
                              <div class="reply-bubble-body">{lead.message as string}</div>
                              <div class="reply-bubble-meta">{new Date(lead.submitted_at as string).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' })} · {lead.name as string}</div>
                            </div>
                          )}
                          {replies.map((r) => (
                            <div class={`reply-bubble${r.direction === 'inbound' ? ' reply-bubble--inbound' : ''}`}>
                              <div class="reply-bubble-subject">{r.subject}</div>
                              <div class="reply-bubble-body">{r.direction === 'inbound' ? stripQuoted(r.message) : r.message}</div>
                              <div class="reply-bubble-meta">
                                {new Date(r.sent_at).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' })}
                                {' · '}{r.direction === 'inbound' ? `${lead.name as string} <${lead.email as string}>` : 'You (MSOIT)'}
                              </div>
                            </div>
                          ))}
                        </div>
                      </div>
                    );
                  })()}
                </td>
                <td class="mono">{lead.phone as string || '—'}</td>
                <td>{lead.area ? <span class="tag tag-area">{lead.area as string}</span> : '—'}</td>
                <td style="max-width:280px;white-space:pre-wrap;">{lead.message as string || '—'}</td>
                <td><span class="tag">{lead.language as string || '—'}</span></td>
                <td class="mono">
                  {lead.utm_source ? <span>{lead.utm_source as string}</span> : <span style="color:#aaa">direct</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
)}

<!-- Reply modal -->
<div class="modal-overlay" id="reply-modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal">
    <div class="modal-header">
      <h2 id="modal-title">Reply to Lead</h2>
      <button class="modal-close" id="modal-close-btn" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body">
      <div class="modal-field">
        <label>To</label>
        <input type="email" id="reply-to" readonly style="background:#f5f5f5;color:#555;" />
      </div>
      <div class="modal-field">
        <label>Subject</label>
        <input type="text" id="reply-subject" />
      </div>
      <div class="modal-field">
        <label>Message</label>
        <textarea id="reply-message" placeholder="Write your reply..."></textarea>
      </div>
      <div class="send-status" id="send-status" style="display:none;"></div>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" id="modal-cancel-btn">Cancel</button>
      <button class="btn-send" id="modal-send-btn">Send Reply</button>
    </div>
  </div>
</div>

<script>
  // Status dropdowns
  document.querySelectorAll<HTMLSelectElement>('.status-select').forEach((sel) => {
    sel.addEventListener('change', async () => {
      const id = sel.dataset.id!;
      const status = sel.value;
      sel.classList.add('saving');
      sel.disabled = true;
      try {
        const res = await fetch('/api/admin-update-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, status }),
        });
        if (res.ok) {
          sel.dataset.status = status;
        } else {
          alert('Failed to update status.');
        }
      } catch {
        alert('Network error updating status.');
      } finally {
        sel.classList.remove('saving');
        sel.disabled = false;
      }
    });
  });

  // Delete buttons
  document.querySelectorAll<HTMLButtonElement>('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      if (!confirm('Delete this lead and all its replies? This cannot be undone.')) return;
      const id = btn.dataset.id!;
      btn.disabled = true;
      btn.textContent = '...';
      try {
        const res = await fetch('/api/admin-delete-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (res.ok) {
          btn.closest('tr')?.remove();
        } else {
          alert('Failed to delete lead.');
          btn.disabled = false;
          btn.textContent = 'Delete';
        }
      } catch {
        alert('Network error.');
        btn.disabled = false;
        btn.textContent = 'Delete';
      }
    });
  });

  // Reply modal
  var modal = document.getElementById('reply-modal');
  var toInput = document.getElementById('reply-to') as HTMLInputElement;
  var subjectInput = document.getElementById('reply-subject') as HTMLInputElement;
  var messageInput = document.getElementById('reply-message') as HTMLTextAreaElement;
  var sendBtn = document.getElementById('modal-send-btn') as HTMLButtonElement;
  var statusEl = document.getElementById('send-status');
  var replyName = '';
  var replyLeadId = '';

  function openModal(email: string, name: string, area: string, leadId: string, lastSubject: string) {
    replyName = name;
    replyLeadId = leadId;
    toInput.value = email;
    if (lastSubject) {
      subjectInput.value = lastSubject.startsWith('Re:') ? lastSubject : 'Re: ' + lastSubject;
    } else {
      subjectInput.value = 'Re: Your request' + (area ? ' — ' + area : '') + ' | MSOIT';
    }
    messageInput.value = '';
    if (statusEl) { statusEl.style.display = 'none'; statusEl.textContent = ''; }
    sendBtn.disabled = false;
    modal!.classList.add('open');
    messageInput.focus();
  }

  function closeModal() {
    modal!.classList.remove('open');
  }

  document.querySelectorAll<HTMLButtonElement>('.reply-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      openModal(btn.dataset.email || '', btn.dataset.name || '', btn.dataset.area || '', btn.dataset.id || '', btn.dataset.lastSubject || '');
    });
  });

  document.getElementById('modal-close-btn')!.addEventListener('click', closeModal);
  document.getElementById('modal-cancel-btn')!.addEventListener('click', closeModal);
  modal!.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  sendBtn.addEventListener('click', async () => {
    var subject = subjectInput.value.trim();
    var message = messageInput.value.trim();
    if (!subject || !message) { alert('Subject and message are required.'); return; }

    sendBtn.disabled = true;
    sendBtn.textContent = 'Sending...';
    if (statusEl) statusEl.style.display = 'none';

    try {
      var res = await fetch('/api/admin-reply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ to: toInput.value, name: replyName, subject, message, leadId: replyLeadId }),
      });
      if (res.ok) {
        if (statusEl) { statusEl.textContent = '✓ Reply sent successfully.'; statusEl.className = 'send-status ok'; statusEl.style.display = 'block'; }
        sendBtn.textContent = 'Sent';
        setTimeout(() => { closeModal(); window.location.reload(); }, 1800);
      } else {
        var err = await res.json().catch(() => ({ error: 'Unknown error' }));
        if (statusEl) { statusEl.textContent = '✗ ' + (err.error || 'Failed to send.'); statusEl.className = 'send-status err'; statusEl.style.display = 'block'; }
        sendBtn.disabled = false;
        sendBtn.textContent = 'Send Reply';
      }
    } catch {
      if (statusEl) { statusEl.textContent = '✗ Network error. Try again.'; statusEl.className = 'send-status err'; statusEl.style.display = 'block'; }
      sendBtn.disabled = false;
      sendBtn.textContent = 'Send Reply';
    }
  });
</script>
</body>
</html>
