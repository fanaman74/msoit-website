---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/sections/CTASection.astro';
import Button from '../components/ui/Button.astro';

const topics = [
  { title: 'Current business processes', desc: 'We map how your team actually works today to spot where AI could reduce friction or eliminate manual steps.' },
  { title: 'Repetitive manual work', desc: 'Data entry, copy-pasting, chasing approvals — we identify the tasks that drain time and can be automated.' },
  { title: 'Document & email-heavy workflows', desc: 'Contracts, reports, inboxes — we assess where AI can help you find, summarise and act on information faster.' },
  { title: 'Internal knowledge management', desc: 'How does your team find answers? We look at whether AI search or knowledge tools could reduce wasted effort.' },
  { title: 'Customer support opportunities', desc: 'From FAQ automation to smarter triaging, we explore where AI can improve response times without losing quality.' },
  { title: 'Microsoft Copilot readiness', desc: 'We assess whether your Microsoft 365 environment is ready to get real value from Copilot — or what needs to change first.' },
  { title: 'Data privacy & security', desc: 'We flag where AI introduces data risks, GDPR concerns or governance gaps before you commit to any tool.' },
  { title: 'AI governance & acceptable use', desc: 'We help you define clear internal rules for how AI should and should not be used in your business.' },
  { title: 'Tool selection & implementation', desc: 'We recommend specific tools matched to your situation, with an honest view of cost, complexity and vendor lock-in.' },
  { title: 'Prioritised roadmap', desc: 'Everything is ranked so you know what to tackle first for the fastest, safest return on effort.' },
];

const deliverables = [
  { title: 'AI opportunity summary', desc: 'A plain-language overview of where AI can realistically add value in your business.' },
  { title: 'Prioritised use-case list', desc: 'Your top AI opportunities ranked by impact and ease of implementation.' },
  { title: 'Quick wins identified', desc: 'Specific tasks or processes you can automate or improve within weeks, not months.' },
  { title: 'Risk & privacy considerations', desc: 'An honest look at data risks, GDPR implications, and what to watch out for.' },
  { title: 'Recommended tools or platforms', desc: 'Concrete suggestions — Microsoft Copilot, custom GPTs, or other tools — matched to your context.' },
  { title: 'Practical AI roadmap', desc: 'A phased plan so you know what to do first, second, and later.' },
  { title: 'Suggested next steps', desc: 'Clear actions you can take immediately, with or without further help from us.' },
];
---

<Layout
  title="AI Opportunity Review for Belgian SMEs"
  description="Understand where AI can help your Belgian SME with a practical review of processes, risks, tools and realistic AI use cases."
  keywords={['AI consulting Belgium', 'AI opportunity review Belgium', 'AI for SMEs Belgium', 'Microsoft Copilot readiness Belgium', 'AI document search Belgium']}
>
  <section class="section-shell bg-white py-20">
    <div class="surface-line pointer-events-none absolute inset-0" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-7xl px-6" data-reveal>
      <p class="mb-5 text-sm font-bold text-accent">AI Opportunity Review</p>
      <h1 class="text-balance max-w-5xl text-6xl font-bold leading-[0.88] text-[#111111] sm:text-8xl">AI with a clear business case.</h1>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-[#444444]">Understand where AI can genuinely help your Belgian SME before investing in tools or platforms.</p>
      <div class="mt-8">
        <Button href="/contact" variant="primary" size="lg">Book an AI Opportunity Review</Button>
      </div>
    </div>
  </section>

  <section class="section-shell bg-surface py-16">
    <div class="relative mx-auto grid max-w-7xl gap-6 px-6 md:grid-cols-2" data-reveal>
      <p class="border border-[#111111] bg-white p-6 text-lg leading-relaxed text-[#444444]">Many businesses are interested in AI, but they are not sure where to start. Some tools promise too much, while many companies do not yet have the right data, processes or governance in place.</p>
      <p class="border border-[#111111] bg-white p-6 text-lg leading-relaxed text-[#444444]">The AI Opportunity Review helps your business identify realistic, practical and safe AI use cases. It focuses on where AI can save time, improve document handling, reduce repetitive work and support better decisions.</p>
    </div>
  </section>

  <section class="section-shell bg-white py-20">
    <div class="relative mx-auto max-w-5xl px-6" data-reveal>
      <h2 class="text-balance text-center text-5xl font-bold leading-[0.95] text-[#111111]">What the Review Covers</h2>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
        {topics.map((t) => (
          <div data-stagger-item class="group flex flex-col border border-[#111111] bg-surface p-6 transition-colors hover:bg-white">
            <div class="mb-4 flex h-8 w-8 items-center justify-center bg-accent transition-colors group-hover:bg-[#111111]">
              <svg class="h-4 w-4 text-[#111111] transition-colors group-hover:text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h3 class="text-sm font-bold text-[#111111]">{t.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[#555555]">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell bg-[#111111] py-20">
    <div class="relative mx-auto max-w-6xl px-6">
      <h2 class="text-center text-5xl font-bold leading-[0.95] text-white" data-reveal>What You Receive</h2>
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
        {deliverables.map((d) => (
          <div data-stagger-item class="group flex flex-col border border-white/20 bg-white/5 p-6 transition-colors hover:bg-white/10">
            <div class="mb-4 flex h-8 w-8 items-center justify-center bg-accent transition-colors group-hover:bg-black">
              <svg class="h-4 w-4 text-[#111111] transition-colors group-hover:text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h3 class="text-base font-bold text-white">{d.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-white/60">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
