---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/sections/CTASection.astro';
import Button from '../components/ui/Button.astro';

const topics = [
  'Current business processes',
  'Repetitive manual work',
  'Document and email-heavy workflows',
  'Internal knowledge management',
  'Customer support opportunities',
  'Microsoft Copilot readiness',
  'Data privacy and security considerations',
  'AI governance and acceptable use',
  'Tool selection and implementation options',
  'Prioritised roadmap',
];

const deliverables = [
  'AI opportunity summary',
  'Prioritised use-case list',
  'Quick wins identified',
  'Risk and privacy considerations',
  'Recommended tools or platforms',
  'Practical AI roadmap',
  'Suggested next steps',
];
---

<Layout title="AI Opportunity Review" description="Understand where AI can help your business with a practical review of processes, risks, tools and realistic AI use cases.">
  <section class="section-shell bg-white py-20">
    <div class="surface-line pointer-events-none absolute inset-0" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-7xl px-6" data-reveal>
      <p class="mb-5 text-sm font-bold text-accent">AI Opportunity Review</p>
      <h1 class="text-balance max-w-5xl text-6xl font-bold leading-[0.88] text-[#111111] sm:text-8xl">AI with a clear business case.</h1>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-[#444444]">Understand where AI can genuinely help your business before investing in tools or platforms.</p>
      <div class="mt-8">
        <Button href="/contact" variant="primary" size="lg">Book an AI Opportunity Review</Button>
      </div>
    </div>
  </section>

  <section class="section-shell bg-surface py-16">
    <div class="relative mx-auto grid max-w-7xl gap-6 px-6 md:grid-cols-2" data-reveal>
      <p class="border border-[#111111] bg-white p-6 text-lg leading-relaxed text-[#444444]">Many businesses are interested in AI, but they are not sure where to start. Some tools promise too much, while many companies do not yet have the right data, processes or governance in place.</p>
      <p class="border border-[#111111] bg-white p-6 text-lg leading-relaxed text-[#444444]">The AI Opportunity Review helps your business identify realistic, practical and safe AI use cases. It focuses on where AI can save time, improve document handling, reduce repetitive work and support better decisions.</p>
    </div>
  </section>

  <section class="section-shell bg-white py-20">
    <div class="relative mx-auto max-w-5xl px-6" data-reveal>
      <h2 class="text-balance text-center text-5xl font-bold leading-[0.95] text-[#111111]">What the Review Covers</h2>
      <div class="mt-10 grid gap-4 sm:grid-cols-2" data-stagger>
        {topics.map((t) => (
          <div data-stagger-item class="flex items-start gap-3 border border-[#111111] bg-surface p-4">
            <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            <span class="text-sm text-[#444444]">{t}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell bg-[#111111] py-20">
    <div class="relative mx-auto max-w-4xl px-6" data-reveal>
      <h2 class="text-center text-5xl font-bold leading-[0.95] text-white">What You Receive</h2>
      <ul class="mt-10 space-y-4" data-stagger>
        {deliverables.map((d) => (
          <li data-stagger-item class="flex items-center gap-3 border border-white bg-white p-4 text-[#111111]">
            <svg class="h-5 w-5 flex-shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="text-lg">{d}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTASection />
</Layout>
