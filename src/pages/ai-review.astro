---
import Layout from '../layouts/Layout.astro';
import CTASection from '../components/sections/CTASection.astro';
import Button from '../components/ui/Button.astro';

const topics = [
  'Current business processes',
  'Repetitive manual work',
  'Document and email-heavy workflows',
  'Internal knowledge management',
  'Customer support opportunities',
  'Microsoft Copilot readiness',
  'Data privacy and security considerations',
  'AI governance and acceptable use',
  'Tool selection and implementation options',
  'Prioritised roadmap',
];

const deliverables = [
  'AI opportunity summary',
  'Prioritised use-case list',
  'Quick wins identified',
  'Risk and privacy considerations',
  'Recommended tools or platforms',
  'Practical AI roadmap',
  'Suggested next steps',
];
---

<Layout title="AI Opportunity Review" description="Understand where AI can help your business with a practical review of processes, risks, tools and realistic AI use cases.">
  <!-- Hero -->
  <section class="bg-navy-900 py-20">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h1 class="text-4xl font-bold text-white sm:text-5xl">AI Opportunity Review</h1>
      <p class="mt-4 text-lg text-slate-400 max-w-2xl mx-auto">Understand where AI can genuinely help your business before investing in tools or platforms.</p>
      <div class="mt-8">
        <Button href="/contact" variant="primary" size="lg">Book an AI Opportunity Review</Button>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="bg-white py-16">
    <div class="mx-auto max-w-3xl px-6">
      <p class="text-lg leading-relaxed text-slate-700">Many businesses are interested in AI, but they are not sure where to start. Some tools promise too much, while many companies do not yet have the right data, processes or governance in place.</p>
      <p class="mt-4 text-lg leading-relaxed text-slate-700">The AI Opportunity Review helps your business identify realistic, practical and safe AI use cases. It focuses on where AI can save time, improve document handling, reduce repetitive work and support better decisions.</p>
    </div>
  </section>

  <!-- What the Review Covers -->
  <section class="bg-surface py-20">
    <div class="mx-auto max-w-4xl px-6">
      <h2 class="text-3xl font-bold text-slate-900 text-center">What the Review Covers</h2>
      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {topics.map((t) => (
          <div class="flex items-start gap-3 rounded-lg bg-white p-4 border border-slate-200">
            <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            <span class="text-sm text-slate-700">{t}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Deliverables -->
  <section class="bg-navy-900 py-20">
    <div class="mx-auto max-w-3xl px-6">
      <h2 class="text-3xl font-bold text-white text-center">What You Receive</h2>
      <ul class="mt-10 space-y-4">
        {deliverables.map((d) => (
          <li class="flex items-center gap-3 text-white">
            <svg class="h-5 w-5 flex-shrink-0 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="text-lg">{d}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTASection />
</Layout>
